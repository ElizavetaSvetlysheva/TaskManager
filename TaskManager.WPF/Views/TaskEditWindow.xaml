<Window x:Class="TaskManager.WPF.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TaskManager.Core.Models;assembly=TaskManager.Core"
        xmlns:vm="clr-namespace:TaskManager.WPF.ViewModels"
        Title="Задача" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#FDF6EE" FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#B0A090"/>
            <Setter Property="Margin"     Value="0,14,0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding"          Value="9,7"/>
            <Setter Property="BorderBrush"      Value="#D9BFA0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Background"       Value="#FFFBF4"/>
            <Setter Property="Foreground"       Value="#2C2018"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="Background"       Value="#FFFBF4"/>
            <Setter Property="BorderBrush"      Value="#D9BFA0"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background"  Value="#FFFBF4"/>
            <Setter Property="BorderBrush" Value="#D9BFA0"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        
        <Border DockPanel.Dock="Top"
                Background="#3D4E6B"
                BorderBrush="#E8612A" BorderThickness="0,0,0,3"
                Padding="18,16">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                       Foreground="#EEF2FA" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#EFE0CC"
                BorderBrush="#D9BFA0" BorderThickness="0,1,0,0"
                Padding="18,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Width="90" Padding="0,8"
                        Click="CancelClick" Cursor="Hand"
                        Background="#E0CDBB" Foreground="#5C5048"
                        BorderThickness="0"/>
                <Button Content="Сохранить" Width="110" Padding="0,8" Margin="10,0,0,0"
                        Click="SaveClick" Cursor="Hand"
                        Background="#3D4E6B" Foreground="#EEF2FA"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="18,4,18,18">
            <TextBlock Text="НАЗВАНИЕ *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TitleBox"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="ОПИСАНИЕ" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ПРИОРИТЕТ" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{x:Static vm:TaskItemViewModel.PriorityList}"
                              SelectedItem="{Binding PriorityRu}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="СТАТУС" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{x:Static vm:TaskItemViewModel.StatusList}"
                              SelectedItem="{Binding StatusRu}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="СРОК ВЫПОЛНЕНИЯ" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding DueDate}" Padding="4"/>

            <CheckBox Content="★  Важная задача"
                      IsChecked="{Binding IsImportant}"
                      Margin="0,16,0,0" FontSize="13"
                      Foreground="#5C5048" Cursor="Hand"/>
        </StackPanel>
    </DockPanel>
</Window>
